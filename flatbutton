import 'package:flutter/material.dart';

void main() {
  runApp(MyApp());
}

class MyApp extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      home: Scaffold(
        appBar: AppBar(
          title: Text("FlatButton Example"),
        ),
        body: Center(
          child: FlatButton(
            onPressed: () {
              print("Button Pressed");
            },
            color: Colors.blue,
            textColor: Colors.white,
            child: Text("Click Me"),
          ),
        ),
      ),
    );
  }
}
