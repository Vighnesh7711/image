import 'package:flutter/material.dart';

void main() {
  runApp(MyApp());
}

class MyApp extends StatelessWidget {
  @override
  Widget build(BuildContext context) {
    return MaterialApp(
      home: Scaffold(
        appBar: AppBar(
          title: Text("RaisedButton Example"),
        ),
        body: Center(
          child: RaisedButton(
            onPressed: () {
              print("Button Clicked");
            },
            color: Colors.green,
            textColor: Colors.white,
            elevation: 10,
            child: Text("Press Me"),
          ),
        ),
      ),
    );
  }
}
